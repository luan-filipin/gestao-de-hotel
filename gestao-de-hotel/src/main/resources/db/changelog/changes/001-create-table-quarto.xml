<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001" author="luan">
        <createTable tableName="quarto">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="numero_quarto" type="INT">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="tipo_quarto" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="preco_por_noite" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="capacidade" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="descricao" type="TEXT"/>

            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

</databaseChangeLog>
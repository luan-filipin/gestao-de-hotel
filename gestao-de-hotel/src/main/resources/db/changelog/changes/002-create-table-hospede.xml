<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002" author="luan">
        <createTable tableName="hospede">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="codigo" type="VARCHAR(10)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="nome" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>

            <column name="cpf" type="VARCHAR(11)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="telefone" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="email" type="VARCHAR(150)">
                <constraints unique="true"/>
            </column>

            <column name="data_nascimento" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="data_cadastro" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="nacionalidade" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="observacao" type="TEXT"/>

        </createTable>
    </changeSet>

</databaseChangeLog>
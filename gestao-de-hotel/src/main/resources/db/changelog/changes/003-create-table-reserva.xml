<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003" author="luan">
        <createTable tableName="reserva">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="data_criacao" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="data_check_in" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="data_check_out" type="DATE"/>

            <column name="valor_total" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="quarto_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_reserva_quarto"
                             references="quarto(id)"
                />
            </column>

            <column name="hospede_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_reserva_hospede"
                             references="hospede(id)"
                />
            </column>

            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="observacao" type="TEXT"/>

        </createTable>
    </changeSet>
</databaseChangeLog>